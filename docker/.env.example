# Copy to docker/.env and adjust. docker-compose.ha.yml reads from this file.
#
# GRAYLOG_PASSWORD_SECRET: pepper used to salt stored passwords. Must be >=16 chars
# and identical across all Graylog nodes. Generate with:
#   pwgen -N 1 -s 96
GRAYLOG_PASSWORD_SECRET=ChangeMeToSomethingLongAndRandomAtLeast16Chars

# GRAYLOG_ROOT_PASSWORD_SHA2: sha256 hex of the admin password.
# Default below is sha256("admin") — change for anything public.
# Generate a new one with:
#   echo -n 'your-password' | sha256sum
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# External URI Graylog advertises to the browser. For local dev leave as-is.
# On the VPS set to e.g. https://dashboard.example.com/ (behind Nginx TLS).
GRAYLOG_HTTP_EXTERNAL_URI=http://localhost:9000/

# OpenSearch initial admin password (required by 2.12+ even with security disabled).
OPENSEARCH_ADMIN_PASSWORD=<REDACTED-OPENSEARCH-PASSWORD>
